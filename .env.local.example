# Database (SQLite local file by default; swap to Turso URL in prod)
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth — create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel Blob — for production image uploads.
# Without this, uploads write to public/uploads/ (fine locally; vanishes on Vercel deploys).
# Create at: Vercel project → Storage → Blob → Connect → copy token.
BLOB_READ_WRITE_TOKEN=

# Resend — for the contact form
RESEND_API_KEY=
